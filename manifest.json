{
  "manifest_version": 3,
  "name": "WinBid - Upwork/Fiverr Proposal Generator",
  "version": "1.0",
  "description": "Generate winning proposals for Upwork, Freelancer, Fiverr and more in seconds",
  "permissions": [
    "activeTab",
    "scripting",
    "storage"
  ],
  "host_permissions": [
    "https://www.upwork.com/*",
    "https://www.freelancer.com/*",
    "https://www.fiverr.com/*",
    "https://www.guru.com/*",
    "https://www.peopleperhour.com/*",
    "https://winbid-flame.vercel.app/*"
],
  "action": {
    "default_popup": "popup.html",
    "default_icon": {
      "16": "icon16.png",
      "48": "icon48.png",
      "128": "icon128.png"
    }
},
  "content_scripts": [
    {
      "matches": ["https://www.upwork.com/*",
    "https://www.freelancer.com/*",
    "https://www.fiverr.com/*",
    "https://www.guru.com/*",
    "https://www.peopleperhour.com/*"],
      "js": ["content.js"]
    }
  ]
}